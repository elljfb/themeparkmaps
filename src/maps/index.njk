---
layout: layouts/base.njk
title: Maps
description: Browse theme park maps by park, year, and era.
---

<section class="page-hero compact-hero">
  <div class="container">
    <h1>Maps Archive</h1>
    <p>Browse placeholder entries for the growing archive. Swap in scans, photos, and notes as your collection grows.</p>
  </div>
</section>

<section class="content-band">
  <div class="container">
    <div class="category-search">
      <div class="hero-search-wrapper">
        <span class="search-icon">
          <svg class="icon" aria-hidden="true"><use href="#icon-search"></use></svg>
        </span>
        <input type="text" placeholder="Search for a park, map, or year..." class="hero-search-input" data-filter-input>
      </div>
    </div>

    <div class="map-grid" data-filter-list>
      {% for map in collections.maps %}
        <article class="map-card" data-filter-item="{{ map.data.title }} {{ map.data.park }} {{ map.data.parkSlug }} {{ map.data.year }} {{ map.data.decade }}">
          <div class="map-card-image-wrapper">
            <a href="{{ map.url }}">
              <img src="{{ map.data.image }}" alt="{{ map.data.title }} placeholder scan">
            </a>
            <span class="map-card-year">{{ map.data.year }}</span>
          </div>
          <div class="map-card-content">
            <span class="eyebrow">{{ map.data.tag }}</span>
            <h3><a href="{{ map.url }}">{{ map.data.title }}</a></h3>
            <p><a href="/parks/{{ map.data.parkSlug }}/" class="park-link">{{ map.data.park }}</a></p>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
