<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if title %}{{ title }} | {% endif %}{{ site.name }}</title>
    <meta name="description" content="{{ description or excerpt or site.description }}">
    <link rel="icon" href="/assets/img/themeparkmaps-transparent-white.png">
    <!-- Google Fonts for premium design -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400..700&family=Outfit:wght@300..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/styles.css">
    <script src="https://analytics.ahrefs.com/analytics.js" data-key="K+7Gi0ye2sTnN6A7HriU0w" async></script>
  </head>
  <body>
    <svg class="icon-sprite" aria-hidden="true">
      <symbol id="icon-home" viewBox="0 0 24 24"><path d="M3 10.8 12 3l9 7.8v9.7a.5.5 0 0 1-.5.5h-5.2v-6.4H8.7V21H3.5a.5.5 0 0 1-.5-.5v-9.7Z"/></symbol>
      <symbol id="icon-map" viewBox="0 0 24 24"><path d="m9 18-6 3V6l6-3 6 3 6-3v15l-6 3-6-3Zm0-13v11m6-8v11"/></symbol>
      <symbol id="icon-castle" viewBox="0 0 24 24"><path d="M4 21V9l2 1.5L8 9l2 1.5L12 9l2 1.5L16 9l2 1.5L20 9v12H4Zm3-12V5l2 1.5L11 5v4m2 0V5l2 1.5L17 5v4M8 21v-5a4 4 0 0 1 8 0v5"/></symbol>
      <symbol id="icon-calendar" viewBox="0 0 24 24"><path d="M5 4h14a2 2 0 0 1 2 2v14H3V6a2 2 0 0 1 2-2Zm0 6h14M8 2v4m8-4v4"/></symbol>
      <symbol id="icon-pencil" viewBox="0 0 24 24"><path d="M4 20h4L19.5 8.5l-4-4L4 16v4Zm10-14 4 4"/></symbol>
      <symbol id="icon-info" viewBox="0 0 24 24"><path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm0-10v6m0-10h.01"/></symbol>
      <symbol id="icon-search" viewBox="0 0 24 24"><path d="m20 20-4.5-4.5M10.8 18a7.2 7.2 0 1 1 0-14.4 7.2 7.2 0 0 1 0 14.4Z"/></symbol>
      <symbol id="icon-arrow" viewBox="0 0 24 24"><path d="M5 12h14m-6-6 6 6-6 6"/></symbol>
      <symbol id="icon-mail" viewBox="0 0 24 24"><path d="M4 6h16v12H4V6Zm0 1 8 6 8-6"/></symbol>
      <symbol id="icon-globe" viewBox="0 0 24 24"><path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm-9-9h18M12 3a14 14 0 0 1 0 18m0-18a14 14 0 0 0 0 18"/></symbol>
      <symbol id="icon-flag" viewBox="0 0 24 24"><path d="M6 21V4m0 1h12l-2.2 4L18 13H6"/></symbol>
      <symbol id="icon-tower" viewBox="0 0 24 24"><path d="M8 21h8L14 4h-4L8 21Zm1-10h6M7 21h10M9 4 8 2m7 2 1-2"/></symbol>
      <symbol id="icon-landmark" viewBox="0 0 24 24"><path d="M4 10h16L12 4 4 10Zm2 0v8m4-8v8m4-8v8m4-8v8M4 21h16M3 18h18"/></symbol>
      <symbol id="icon-chevron-down" viewBox="0 0 24 24"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></symbol>
      <symbol id="icon-facebook" viewBox="0 0 24 24"><path d="M14 8.7V7.1c0-.7.5-1.1 1.2-1.1H18V2.3A18 18 0 0 0 14.7 2C11.4 2 9 4 9 6.8v2.9H6v4.1h3V22h4.5v-8.2h3.1l.6-4.1h-3.7Z"/></symbol>
      <symbol id="icon-x" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></symbol>
      <symbol id="icon-instagram" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M7.75 2h8.5A5.76 5.76 0 0 1 22 7.75v8.5A5.76 5.76 0 0 1 16.25 22h-8.5A5.76 5.76 0 0 1 2 16.25v-8.5A5.76 5.76 0 0 1 7.75 2Zm0 2A3.76 3.76 0 0 0 4 7.75v8.5A3.76 3.76 0 0 0 7.75 20h8.5A3.76 3.76 0 0 0 20 16.25v-8.5A3.76 3.76 0 0 0 16.25 4h-8.5ZM12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Zm0 2a2 2 0 1 1 0 4 2 2 0 0 1 0-4Zm5.2-2.2a1.2 1.2 0 1 0 0-2.4 1.2 1.2 0 0 0 0 2.4Z"/></symbol>
      <symbol id="icon-youtube" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2C5.12 19.5 12 19.5 12 19.5s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33ZM9.75 15.02l5.75-3.27-5.75-3.27v6.54Z"/></symbol>
      <symbol id="icon-tiktok" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.68v13.67a2.4 2.4 0 1 1-4.77-1.58 2.41 2.41 0 0 1 3.06 2.4v-3.23a6.16 6.16 0 0 0-5.83 6.09 6.11 6.11 0 1 0 11.25-5.08z"/></symbol>
    </svg>

    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="/" aria-label="{{ site.name }} home">
          <img src="/assets/img/themeparkmaps-transparent.png" alt="{{ site.name }}">
        </a>
        <button class="menu-toggle" type="button" data-menu-toggle aria-label="Open navigation">
          <span></span><span></span><span></span>
        </button>
        <nav class="site-nav" aria-label="Main navigation" data-site-nav>
          {% for item in site.nav %}
            <a href="{{ item.url }}" class="nav-link{% if page.url == item.url %} is-active{% endif %}">
              <svg class="icon" aria-hidden="true"><use href="#icon-{{ item.icon }}"></use></svg>
              <span>{{ item.label }}</span>
              {% if item.label == 'Maps' or item.label == 'Parks' or item.label == 'Years' %}
                <svg class="icon nav-chevron" aria-hidden="true"><use href="#icon-chevron-down"></use></svg>
              {% endif %}
            </a>
          {% endfor %}
        </nav>
      </div>
    </header>

    <main>
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <img src="/assets/img/themeparkmaps-white.png" alt="{{ site.name }}">
          <p>A growing collection of theme park maps from around the world, through the years.</p>
        </div>
        <div>
          <h2>Explore</h2>
          <a href="/maps/">Maps</a>
          <a href="/parks/">Parks</a>
          <a href="/years/">Years</a>
          <a href="/blog/">Blog</a>
        </div>
        <div>
          <h2>Information</h2>
          <a href="/about/">About Us</a>
          <a href="/contact/">Contact Us</a>
          <a href="/faq/">FAQ</a>
          <a href="/sitemap.xml">Sitemap</a>
        </div>
        <div>
          <h2>Connect</h2>
          <div class="social-links">
            {% for social in site.socials %}
              <a href="{{ social.url }}" aria-label="{{ social.label }}" class="social-link-item">
                <svg class="icon" aria-hidden="true">
                  <use href="#icon-{{ social.label | lower }}"></use>
                </svg>
              </a>
            {% endfor %}
          </div>
        </div>
      </div>
      <p class="copyright container">&copy; 2026 Theme Park Maps .net - All rights reserved.</p>
    </footer>

    <script src="/assets/js/main.js"></script>
  </body>
</html>
